<%- include('partials/head', { title, theme }) %>

<main class="dashboard-page">
  <header class="dashboard-top glass-card">
    <div class="brand-block">
      <% if (theme && theme.logo_url) { %>
        <img src="<%= theme.logo_url %>" alt="Logo" class="brand-logo" />
      <% } %>
      <h1><%= (theme && theme.app_name) || 'Ecossistema Omega' %></h1>
      <p><%= (theme && theme.hero_title) || 'Central de Sistemas' %></p>
    </div>

    <div class="dashboard-actions">
      <% if (currentUser && currentUser.is_admin) { %>
        <a class="btn btn-secondary" href="/admin">Painel Admin</a>
      <% } %>

      <form method="post" action="/logout">
        <button type="submit" class="btn btn-ghost">Sair</button>
      </form>
    </div>
  </header>

  <section class="selector-card glass-card">
    <%- include('partials/flash', { flash }) %>

    <h2>Escolha um sistema</h2>
    <p class="muted">Ao clicar, o sistema abre em uma nova aba.</p>

    <div class="system-center-grid">
      <% if (!systems.length) { %>
        <p class="muted">Sem sistemas liberados para seu usuario.</p>
      <% } %>

      <% systems.forEach((system) => { %>
        <a class="system-link" href="<%= system.url %>" target="_blank" rel="noopener noreferrer">
          <span><%= system.name %></span>
          <small><%= system.description || 'Acessar sistema' %></small>
        </a>
      <% }) %>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
