<%- include('partials/head', { title, theme }) %>

<%
  function systemMeta(system) {
    const name = String((system && system.name) || '').toLowerCase();
    if (name.includes('ponto')) {
      return { icon: '⏱', tone: 'tone-time' };
    }
    if (name.includes('despesa')) {
      return { icon: '💰', tone: 'tone-money' };
    }
    if (name.includes('form')) {
      return { icon: '🧾', tone: 'tone-form' };
    }
    if (name.includes('lancamento')) {
      return { icon: '📊', tone: 'tone-launch' };
    }
    return { icon: '🧩', tone: 'tone-default' };
  }
%>

<main class="dashboard-page omega-page">
  <header class="dashboard-top glass-card omega-header">
    <div class="brand-inline">
      <img
        src="<%= fixedLogoUrl %>"
        alt="Omega Distribuidora"
        class="omega-logo"
        onerror="this.onerror=null;this.src='/public/assets/omega-logo.svg';"
      />
      <div class="brand-text">
        <h1><%= (theme && theme.app_name) || 'Ecossistema Omega' %></h1>
        <p>Central de Sistema da Ômega Distribuidora</p>
      </div>
    </div>

    <div class="dashboard-actions">
      <% if (currentUser && currentUser.is_admin) { %>
        <a class="btn btn-secondary" href="/admin">Painel Admin</a>
      <% } %>

      <form method="post" action="/logout">
        <button type="submit" class="btn btn-ghost">Sair</button>
      </form>
    </div>
  </header>

  <section class="selector-card glass-card omega-selector">
    <div class="welcome-banner">
      <div>
        <strong>Bem-vindo de volta, <%= (currentUser && currentUser.username) || 'usuário' %>.</strong>
        <span>Hoje é <%= todayLabel %>.</span>
      </div>
    </div>

    <div class="mobile-system-picker">
      <label for="mobile-system-select" class="small muted">Módulo</label>
      <div class="mobile-picker-row">
        <select id="mobile-system-select" class="omega-select" data-mobile-system-select>
          <option value="">Selecione um módulo</option>
          <% systems.forEach((system) => { %>
            <option
              value="<%= system.id %>"
              data-name="<%= system.name %>"
              data-preview-image="<%= system.preview_image_url || '/public/assets/omega-logo.svg' %>"
            >
              <%= system.name %>
            </option>
          <% }) %>
        </select>
        <a href="#" class="btn btn-primary disabled" data-mobile-open-link target="_blank" rel="noopener noreferrer">Abrir</a>
      </div>
    </div>

    <div class="systems-browser">
      <nav class="system-vertical-list" data-preview-list>
        <% if (!systems.length) { %>
          <p class="muted">Sem sistemas liberados para seu usuário.</p>
        <% } %>

        <% systems.forEach((system) => { %>
          <% const meta = systemMeta(system); %>
          <% const status = (systemStatuses && systemStatuses[system.id]) || { online: false, statusCode: null }; %>
          <a
            class="system-item <%= meta.tone %>"
            href="/go/<%= system.id %>"
            target="_blank"
            rel="noopener noreferrer"
            data-preview-link
            data-system-id="<%= system.id %>"
            data-system-name="<%= system.name %>"
            data-preview-image="<%= system.preview_image_url || '/public/assets/omega-logo.svg' %>"
          >
            <div class="system-item-top">
              <span class="system-icon"><%= meta.icon %></span>
              <span class="system-title"><%= system.name %></span>
              <span class="status-badge <%= status.online ? 'is-online' : 'is-offline' %>">
                <%= status.online ? 'Online' : 'Offline' %>
              </span>
            </div>
            <small><%= system.description || 'Acessar sistema' %></small>
          </a>
        <% }) %>
      </nav>

      <aside class="preview-panel">
        <div class="preview-panel-header">
          <div>
            <h3 data-preview-title>Nenhum módulo selecionado</h3>
          </div>
        </div>

        <div class="preview-frame-wrap">
          <div class="preview-placeholder" data-preview-placeholder>
            Escolha um módulo na lista para ver a miniatura de acesso.
          </div>
          <img
            class="preview-image hidden"
            alt="Miniatura do sistema"
            data-preview-target
            loading="lazy"
          />
        </div>
      </aside>
    </div>
  </section>
</main>

<%- include('partials/foot') %>
