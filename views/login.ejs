<%- include('partials/head', { title, theme }) %>

<main class="auth-page omega-page" style="background-image: linear-gradient(160deg, rgba(4, 10, 30, .88), rgba(5, 16, 47, .82)), url('<%= (theme && theme.background_url) || '' %>');">
  <section class="glass-card auth-card omega-login-card">
    <div class="auth-brand">
      <img
        src="<%= (theme && theme.logo_url) || '/public/assets/omega-logo.svg' %>"
        alt="Omega Distribuidora"
        class="omega-logo"
      />
      <h1><%= (theme && theme.app_name) || 'Ecossistema Omega' %></h1>
      <p><%= (theme && theme.hero_subtitle) || 'Acesso centralizado aos sistemas da empresa.' %></p>
    </div>

    <%- include('partials/flash', { flash }) %>

    <form method="post" action="/login" class="form-stack">
      <label>
        Usuario
        <input type="text" name="username" autocomplete="username" required />
      </label>

      <label>
        Senha
        <input type="password" name="password" autocomplete="current-password" required />
      </label>

      <button type="submit" class="btn btn-primary">Entrar</button>
    </form>
  </section>
</main>

<%- include('partials/foot') %>
