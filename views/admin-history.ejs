<%- include('partials/head', { title, theme }) %>

<%
  function toDateFromDb(value) {
    const raw = String(value || '').trim();
    if (!raw) {
      return null;
    }

    const hasTimezone = /(?:Z|[+-]\d{2}:\d{2})$/i.test(raw);
    const sqliteLike = /^\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}$/.test(raw);

    if (sqliteLike) {
      return new Date(raw.replace(' ', 'T') + 'Z');
    }

    if (!hasTimezone && /^\d{4}-\d{2}-\d{2}T/.test(raw)) {
      return new Date(raw + 'Z');
    }

    return new Date(raw);
  }

  function formatDateTime(value) {
    const date = toDateFromDb(value);
    if (!date || Number.isNaN(date.getTime())) {
      return String(value || '-');
    }
    return new Intl.DateTimeFormat('pt-BR', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
      timeZone: 'America/Fortaleza'
    }).format(date);
  }
%>

<main class="admin-page omega-page">
  <header class="page-header glass-card omega-header">
    <div class="admin-header-left">
      <img src="<%= fixedLogoUrl %>" alt="Omega Distribuidora" class="omega-logo" onerror="this.onerror=null;this.src='/public/assets/omega-logo.svg';" />
      <div>
        <h1>Historico de Acessos</h1>
        <p>Registro de entradas em modulos do ecossistema.</p>
      </div>
    </div>

    <div class="page-actions">
      <details class="admin-nav-dropdown">
        <summary class="btn btn-secondary">Navegacao</summary>
        <div class="admin-nav-menu glass-card">
          <a href="/admin">Menu Admin</a>
          <a href="/admin/users">Usuarios</a>
          <a href="/admin/systems">Sistemas</a>
          <a href="/admin/mappings">Mapeamentos</a>
          <a href="/admin/history">Historico</a>
          <a href="/dashboard">Painel Principal</a>
        </div>
      </details>
    </div>
  </header>

  <%- include('partials/flash', { flash }) %>

  <section class="glass-card admin-section">
    <h2 class="section-title">Ultimos acessos</h2>

    <% if (!historyRows || !historyRows.length) { %>
      <p class="muted">Nenhum acesso registrado ainda.</p>
    <% } else { %>
      <div class="history-table-wrap">
        <table class="history-table">
          <thead>
            <tr>
              <th>Data / Hora</th>
              <th>Usuario</th>
              <th>Modulo</th>
            </tr>
          </thead>
          <tbody>
            <% historyRows.forEach((row) => { %>
              <tr>
                <td><%= formatDateTime(row.accessed_at) %></td>
                <td><%= row.username || `Usuario #${row.user_id || '-'}` %></td>
                <td><%= row.system_name || `Modulo #${row.system_id || '-'}` %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<%- include('partials/foot') %>
